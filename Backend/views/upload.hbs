<!-- En tu upload.hbs -->
<div class="container upload-page-container">
    <h1 class="page-title">Subir Videos de Ejercicios</h1>
    
    <form id="uploadForm">
        <div class="form-group">
            <label for="videoTitle">Título del Video *</label>
            <input type="text" id="videoTitle" name="title" required placeholder="Ej: Sentadillas con barra">
        </div>

        <div class="form-group">
            <label for="exerciseType">Tipo de Ejercicio *</label>
            <select id="exerciseType" name="exerciseType" required>
                <option value="">Selecciona un tipo</option>
                <option value="fuerza">Fuerza</option>
                <option value="cardio">Cardio</option>
                <option value="flexibilidad">Flexibilidad</option>
                <option value="equilibrio">Equilibrio</option>
                <option value="recuperacion">Recuperación</option>
            </select>
        </div>

        <!-- Área de drag & drop -->
        <div class="upload-area" id="uploadArea">
            <div class="upload-content">
                <i class="fas fa-cloud-upload-alt"></i>
                <h3>Arrastra tus videos aquí</h3>
                <p>o haz clic para seleccionar archivos</p>
                <p class="file-info">Máximo 3 videos • 100MB por video</p>
                <p class="file-types">Formatos: MP4, AVI, MOV, MKV, WebM</p>
            </div>
            <input 
                type="file" 
                id="fileInput" 
                multiple 
                accept="video/mp4,video/avi,video/quicktime,video/x-matroska,video/webm"
                style="display: none;">
        </div>

        <!-- Lista de archivos seleccionados -->
        <div id="fileList" class="file-list"></div>

        <!-- Barra de progreso -->
        <div id="progressBar" class="progress-bar" style="display: none;">
            <div id="progressFill" class="progress-fill">0%</div>
        </div>

        <!-- Botón de subir -->
        <button type="button" id="uploadBtn" class="btn-primary" disabled>
            <i class="fas fa-upload"></i>
            Subir Videos
        </button>
    </form>
</div>

<!-- Incluir SweetAlert -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/upload.js"></script>